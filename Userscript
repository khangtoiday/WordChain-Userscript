  // =============================================
  // QUẢN LÝ TỪ ĐIỂN MỞ RỘNG
  // =============================================
  const STORAGE_KEY = 'noitu_custom_dict_v2';

  function loadCustomDict() {
    try {
      const raw = GM_getValue(STORAGE_KEY, '{}');
      return JSON.parse(raw);
    } catch (e) { return {}; }
  }

  function saveCustomDict(dict) {
    GM_setValue(STORAGE_KEY, JSON.stringify(dict));
  }

  function getMergedDict() {
    const custom = loadCustomDict();
    const merged = {};
    for (const [k, v] of Object.entries(BUILTIN)) merged[k] = [...v];
    for (const [k, v] of Object.entries(custom)) {
      if (!merged[k]) merged[k] = [];
      for (const word of v) {
        if (!merged[k].includes(word)) merged[k].push(word);
      }
    }
    return merged;
  }

  function learnWord(key, newWord) {
    key = key.toLowerCase().trim();
    newWord = newWord.toLowerCase().trim();
    if (!key || !newWord || newWord.split(' ').length < 2) return 'invalid';
    const custom = loadCustomDict();
    if (!custom[key]) custom[key] = [];
    if (custom[key].includes(newWord)) return 'dup';
    if (BUILTIN[key] && BUILTIN[key].includes(newWord)) return 'dup';
    custom[key].push(newWord);
    saveCustomDict(custom);
    return 'ok';
  }

  function forgetWord(key, word) {
    const custom = loadCustomDict();
    if (!custom[key]) return;
    custom[key] = custom[key].filter(w => w !== word);
    if (custom[key].length === 0) delete custom[key];
    saveCustomDict(custom);
  }

  function exportDict() {
    const custom = loadCustomDict();
    const blob = new Blob([JSON.stringify(custom, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'noitu-custom-dict.json';
    a.click();
    URL.revokeObjectURL(url);
  }

  function importDict(jsonStr) {
    try {
      const imported = JSON.parse(jsonStr);
      const custom = loadCustomDict();
      let count = 0;
      for (const [k, v] of Object.entries(imported)) {
        if (!Array.isArray(v)) continue;
        if (!custom[k]) custom[k] = [];
        for (const word of v) {
          if (!custom[k].includes(word)) { custom[k].push(word); count++; }
        }
      }
      saveCustomDict(custom);
      return count;
    } catch (e) { return -1; }
  }

  function countCustomWords() {
    return Object.values(loadCustomDict()).reduce((a, b) => a + b.length, 0);
  }

  // =============================================
  // UTILS
  // =============================================
  function removeAccents(str) {
    return str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/đ/g, "d").replace(/Đ/g, "D").toLowerCase();
  }

  function getLastWord(phrase) {
    const words = phrase.trim().split(/\s+/);
    return words[words.length - 1].toLowerCase();
  }

  function getSuggestions(lastWord) {
    const dict = getMergedDict();
    const key = lastWord.toLowerCase();
    // Chỉ match chính xác — tiếng Việt khác dấu là khác nghĩa hoàn toàn
    if (dict[key]) return { words: dict[key], key };
    return { words: [], key };
  }

  // =============================================
  // POPUP
  // =============================================
  const C = {
    bg: '#0f0f1a', border: '#e94560', accent: '#e94560',
    text: '#e0e0ff', muted: '#555a7a', green: '#00d084',
    divider: '#1e1e35', hov: '#e9456012',
  };

  let popup = null;
  let currentLastWord = '';
  let currentKey = '';

  function createPopup() {
    const el = document.createElement('div');
    el.id = '__noitu__';
    el.style.cssText = `
      position:fixed;z-index:2147483647;
      background:${C.bg};border:1.5px solid ${C.border};border-radius:13px;
      min-width:240px;max-width:350px;
      box-shadow:0 12px 44px rgba(233,69,96,0.22),0 2px 10px rgba(0,0,0,0.5);
      font-family:'Segoe UI',Arial,sans-serif;font-size:13px;
      display:none;pointer-events:auto;overflow:hidden;
    `;
    document.body.appendChild(el);
    return el;
  }

  function renderPopup(lastWord, result) {
    if (!popup) popup = createPopup();
    currentLastWord = lastWord;
    currentKey = result.key || lastWord;

    const custom = loadCustomDict();
    const customWords = custom[currentKey] || [];

    popup.innerHTML = '';

    // Header
    const hd = document.createElement('div');
    hd.style.cssText = `background:${C.border}14;padding:9px 14px 8px;border-bottom:1px solid ${C.border}30;display:flex;align-items:center;justify-content:space-between;`;
    hd.innerHTML = `
      <span style="color:${C.accent};font-weight:800;font-size:11px;letter-spacing:.8px;text-transform:uppercase;">
        🔗 Sau &ldquo;<span style="color:#fff;font-size:12px;">${currentKey}</span>&rdquo;
      </span>
      <span style="color:${C.muted};font-size:10px;">${result.words.length} gợi ý</span>
    `;
    popup.appendChild(hd);

    // List
    // List
    if (!document.getElementById('__noitu_style__')) {
      const style = document.createElement('style');
      style.id = '__noitu_style__';
      style.textContent = `
        #__noitu__ .noitu-list::-webkit-scrollbar { width: 3px; }
        #__noitu__ .noitu-list::-webkit-scrollbar-track { background: transparent; }
        #__noitu__ .noitu-list::-webkit-scrollbar-thumb { background: #e9456055; border-radius: 99px; }
        #__noitu__ .noitu-list::-webkit-scrollbar-thumb:hover { background: #e94560bb; }
      `;
      document.head.appendChild(style);
    }
    const list = document.createElement('div');
    list.className = 'noitu-list';
    list.style.cssText = `padding:6px 8px;max-height:190px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:#e9456055 transparent;`;

    if (result.words.length === 0) {
      list.innerHTML = `<div style="color:${C.muted};font-style:italic;padding:8px 6px;font-size:12px;">Chưa có từ nào — dạy tôi bên dưới! 👇</div>`;
    } else {
      result.words.forEach(word => {
        const isCustom = customWords.includes(word);
        const row = document.createElement('div');
        row.style.cssText = `display:flex;align-items:center;justify-content:space-between;gap:6px;padding:5px 8px;border-radius:7px;cursor:pointer;transition:background .1s;`;

        const lbl = document.createElement('span');
        lbl.textContent = word;
        lbl.style.cssText = isCustom ? `color:${C.green};font-weight:600;` : `color:${C.text};`;

        const acts = document.createElement('span');
        acts.style.cssText = `display:flex;gap:3px;opacity:0;transition:opacity .1s;font-size:13px;`;

        // Copy btn
        const copyBtn = document.createElement('span');
        copyBtn.title = 'Copy';
        copyBtn.textContent = '📋';
        copyBtn.style.cursor = 'pointer';
        copyBtn.onclick = (e) => {
          e.stopPropagation();
          navigator.clipboard.writeText(word).catch(() => {});
          copyBtn.textContent = '✅';
          setTimeout(() => copyBtn.textContent = '📋', 700);
        };
        acts.appendChild(copyBtn);

        // Delete btn (chỉ custom)
        if (isCustom) {
          const delBtn = document.createElement('span');
          delBtn.title = 'Xóa';
          delBtn.textContent = '🗑';
          delBtn.style.cursor = 'pointer';
          delBtn.onclick = (e) => {
            e.stopPropagation();
            if (confirm(`Xóa "${word}" khỏi từ điển?`)) {
              forgetWord(currentKey, word);
              renderPopup(currentLastWord, getSuggestions(currentLastWord));
            }
          };
          acts.appendChild(delBtn);
        }

        row.appendChild(lbl);
        row.appendChild(acts);

        row.onmouseenter = () => { row.style.background = C.hov; acts.style.opacity = '1'; };
        row.onmouseleave = () => { row.style.background = 'transparent'; acts.style.opacity = '0'; };
        row.onclick = () => {
          navigator.clipboard.writeText(word).catch(() => {});
          row.style.background = `${C.green}18`;
          setTimeout(() => row.style.background = 'transparent', 500);
        };

        list.appendChild(row);
      });
    }
    popup.appendChild(list);

    // Learn section
    const learn = document.createElement('div');
    learn.style.cssText = `border-top:1px solid ${C.divider};padding:8px 10px 10px;background:#12122080;`;

    const lbl = document.createElement('div');
    lbl.style.cssText = `color:${C.muted};font-size:10px;margin-bottom:5px;`;
    lbl.textContent = `➕ Dạy từ mới sau "${currentKey}"`;

    const row = document.createElement('div');
    row.style.cssText = 'display:flex;gap:6px;';

    const inp = document.createElement('input');
    inp.type = 'text';
    inp.placeholder = 'vd: bình an, bình minh...';
    inp.style.cssText = `
      flex:1;background:#0a0a18;border:1px solid ${C.divider};border-radius:7px;
      color:${C.text};padding:5px 9px;font-size:12px;outline:none;font-family:inherit;
      transition:border-color .15s;
    `;
    inp.onfocus = () => inp.style.borderColor = C.accent;
    inp.onblur = () => inp.style.borderColor = C.divider;

    const btn = document.createElement('button');
    btn.textContent = 'Học';
    btn.style.cssText = `
      background:${C.accent};color:#fff;border:none;border-radius:7px;
      padding:5px 13px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;
      transition:opacity .15s;white-space:nowrap;
    `;
    btn.onmouseenter = () => btn.style.opacity = '.8';
    btn.onmouseleave = () => btn.style.opacity = '1';

    const doLearn = () => {
      const val = inp.value.trim();
      if (!val) return;
      const res = learnWord(currentKey, val);
      if (res === 'ok') {
        btn.textContent = '✅';
        btn.style.background = C.green;
        setTimeout(() => {
          btn.textContent = 'Học';
          btn.style.background = C.accent;
          inp.value = '';
          renderPopup(currentLastWord, getSuggestions(currentLastWord));
        }, 600);
      } else if (res === 'dup') {
        inp.style.borderColor = C.accent;
        btn.textContent = 'Đã có!';
        setTimeout(() => { btn.textContent = 'Học'; inp.value = ''; inp.style.borderColor = C.divider; }, 900);
      } else {
        inp.style.borderColor = C.accent;
        btn.textContent = 'Cần ≥2 tiếng!';
        setTimeout(() => { btn.textContent = 'Học'; inp.style.borderColor = C.divider; }, 1000);
      }
    };

    btn.onclick = doLearn;
    inp.onkeydown = (e) => { if (e.key === 'Enter') doLearn(); e.stopPropagation(); };

    row.appendChild(inp);
    row.appendChild(btn);
    learn.appendChild(lbl);
    learn.appendChild(row);
    popup.appendChild(learn);

    // Footer
    const ft = document.createElement('div');
    ft.style.cssText = `padding:5px 14px 7px;color:${C.muted};font-size:10px;border-top:1px solid ${C.divider};display:flex;justify-content:space-between;`;
    ft.innerHTML = `<span>Esc đóng &nbsp;·&nbsp; 🟢 từ bạn dạy</span><span style="color:${C.green}">🧠 ${countCustomWords()} từ đã học</span>`;
    popup.appendChild(ft);
  }

  function showPopup(x, y, lastWord, result) {
    renderPopup(lastWord, result);
    popup.style.display = 'block';
    requestAnimationFrame(() => {
      const pw = popup.offsetWidth, ph = popup.offsetHeight;
      let l = x + 10, t = y + 10;
      if (l + pw > window.innerWidth - 10) l = x - pw - 10;
      if (t + ph > window.innerHeight - 10) t = y - ph - 10;
      popup.style.left = l + 'px';
      popup.style.top = t + 'px';
    });
  }

  function hidePopup() {
    if (popup) popup.style.display = 'none';
  }

  // =============================================
  // PANEL QUẢN LÝ (mở từ menu Tampermonkey)
  // =============================================
  function openManager() {
    const totalBuiltin = Object.values(BUILTIN).reduce((a, b) => a + b.length, 0);
    const totalCustom = countCustomWords();

    const ov = document.createElement('div');
    ov.style.cssText = `position:fixed;inset:0;z-index:2147483646;background:rgba(0,0,0,.75);display:flex;align-items:center;justify-content:center;`;

    const panel = document.createElement('div');
    panel.style.cssText = `
      background:${C.bg};border:1.5px solid ${C.border};border-radius:15px;
      padding:26px 28px;min-width:340px;max-width:460px;width:90%;
      font-family:'Segoe UI',Arial,sans-serif;color:${C.text};
      box-shadow:0 20px 60px rgba(233,69,96,0.25);
    `;
    panel.innerHTML = `
      <div style="font-size:17px;font-weight:800;color:${C.accent};margin-bottom:4px;">🔗 Nối Từ Helper — Từ điển</div>
      <div style="color:${C.muted};font-size:12px;margin-bottom:20px;">
        📚 Từ gốc: <b style="color:#fff">${totalBuiltin}</b>
        &nbsp;·&nbsp;
        🟢 Bạn đã dạy: <b style="color:${C.green}">${totalCustom}</b>
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;">
        <button id="__nm_export__" style="background:${C.accent};color:#fff;border:none;border-radius:9px;padding:11px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;">
          ⬇️ Xuất từ đã học ra file JSON
        </button>
        <label id="__nm_importlbl__" style="background:#12122080;color:${C.text};border:2px dashed ${C.divider};border-radius:9px;padding:11px;font-size:13px;cursor:pointer;text-align:center;display:block;transition:border-color .15s;">
          ⬆️ Nhập từ điển từ file JSON
          <input type="file" id="__nm_import__" accept=".json" style="display:none">
        </label>
        <button id="__nm_reset__" style="background:transparent;color:${C.muted};border:1px solid ${C.divider};border-radius:9px;padding:9px;font-size:12px;cursor:pointer;font-family:inherit;">
          🗑 Xóa toàn bộ từ đã học (${totalCustom} từ)
        </button>
      </div>
      <div id="__nm_msg__" style="margin-top:12px;font-size:12px;min-height:18px;"></div>
      <div style="margin-top:16px;text-align:right;">
        <button id="__nm_close__" style="background:transparent;color:${C.muted};border:1px solid ${C.divider};border-radius:8px;padding:7px 18px;font-size:12px;cursor:pointer;font-family:inherit;">Đóng</button>
      </div>
    `;

    ov.appendChild(panel);
    document.body.appendChild(ov);

    const msg = panel.querySelector('#__nm_msg__');
    const lbl = panel.querySelector('#__nm_importlbl__');
    lbl.onmouseenter = () => lbl.style.borderColor = C.accent;
    lbl.onmouseleave = () => lbl.style.borderColor = C.divider;

    panel.querySelector('#__nm_export__').onclick = () => {
      exportDict();
      msg.style.color = C.green;
      msg.textContent = '✅ Đã xuất noitu-custom-dict.json!';
    };

    panel.querySelector('#__nm_import__').onchange = (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (ev) => {
        const count = importDict(ev.target.result);
        if (count >= 0) {
          msg.style.color = C.green;
          msg.textContent = `✅ Nhập thành công ${count} từ mới!`;
        } else {
          msg.style.color = C.accent;
          msg.textContent = '❌ File JSON không hợp lệ!';
        }
      };
      reader.readAsText(file);
    };

    panel.querySelector('#__nm_reset__').onclick = () => {
      if (totalCustom === 0) { msg.style.color = C.muted; msg.textContent = 'Chưa có từ nào để xóa.'; return; }
      if (confirm(`Xóa toàn bộ ${totalCustom} từ đã học? Không thể hoàn tác!`)) {
        saveCustomDict({});
        msg.style.color = C.accent;
        msg.textContent = '🗑 Đã xóa toàn bộ từ đã học.';
      }
    };

    panel.querySelector('#__nm_close__').onclick = () => ov.remove();
    ov.onclick = (e) => { if (e.target === ov) ov.remove(); };
  }

  GM_registerMenuCommand('🔗 Nối Từ — Quản lý từ điển', openManager);

  // =============================================
  // SỰ KIỆN CHÍNH
  // =============================================
  document.addEventListener('mouseup', (e) => {
    if (popup && popup.contains(e.target)) return;
    setTimeout(() => {
      const sel = window.getSelection().toString().trim();
      if (!sel || sel.length < 2) { hidePopup(); return; }
      const lastWord = getLastWord(sel);
      if (!lastWord) { hidePopup(); return; }
      showPopup(e.clientX, e.clientY, lastWord, getSuggestions(lastWord));
    }, 50);
  });

  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') hidePopup(); });
  document.addEventListener('mousedown', (e) => { if (popup && !popup.contains(e.target)) hidePopup(); });

})();
